{
  "name": "mojing-novel-engine",
  "version": "1.0.0",
  "description": "墨境·高概念网文AI创作引擎 - 基于7个真相文件的专业网文创作工具",
  "main": "main.js",
  "author": "MoJing Team",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build:electron": "electron-builder",
    "build:backend": "pyinstaller --onefile --name backend --distpath ../dist/backend backend/main.py",
    "build:all": "npm run build:backend && npm run build:electron",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.mojing.novel-engine",
    "productName": "墨境·高概念网文AI创作引擎",
    "copyright": "Copyright © 2024 MoJing Team",
    "directories": {
      "output": "release",
      "buildResources": "../assets"
    },
    "files": [
      "../frontend/**/*",
      "../backend/**/*",
      "!**/*.pyc",
      "!**/__pycache__"
    ],
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "../assets/icon.ico",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "墨境",
      "installerIcon": "../assets/icon.ico",
      "uninstallerIcon": "../assets/icon.ico",
      "installerHeaderIcon": "../assets/icon.ico"
    },
    "portable": {
      "artifactName": "${productName}-${version}-Portable.${ext}"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "../assets/icon.icns",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "../assets/icon.png",
      "category": "Office"
    }
  }
}
